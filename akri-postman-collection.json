{
  "info": {
    "name": "Akri.dz — API Collection",
    "description": "Collection Postman pour tester tous les endpoints du projet WAMS",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "AUTH_URL", "value": "http://localhost:8001", "type": "string" },
    { "key": "API_URL",  "value": "http://localhost:8002", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register Client",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AUTH_URL}}/api/auth/register/client/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Ahmed Benali\",\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"Password123\",\n  \"phone\": \"0550123456\",\n  \"wilaya\": \"Alger\"\n}"
            }
          }
        },
        {
          "name": "Register Agency",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AUTH_URL}}/api/auth/register/agency/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agency_name\": \"AutoRent Alger\",\n  \"owner_name\": \"Karim Mansouri\",\n  \"email\": \"autorent@example.com\",\n  \"password\": \"Password123\",\n  \"phone\": \"0560123456\",\n  \"wilaya\": \"Alger\",\n  \"rc_number\": \"RC16-12345\"\n}"
            }
          }
        },
        {
          "name": "Login Client",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AUTH_URL}}/api/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"Password123\",\n  \"role\": \"client\"\n}"
            }
          }
        },
        {
          "name": "Login Agency",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AUTH_URL}}/api/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"autorent@example.com\",\n  \"password\": \"Password123\",\n  \"role\": \"agency\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AUTH_URL}}/api/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@akri.dz\",\n  \"password\": \"Admin123456\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "url": "{{AUTH_URL}}/api/auth/verify/"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{AUTH_URL}}/api/auth/me/"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{AUTH_URL}}/api/auth/logout/"
          }
        }
      ]
    },
    {
      "name": "Cars",
      "item": [
        {
          "name": "List Cars (public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{API_URL}}/api/cars/",
              "query": [
                { "key": "wilaya", "value": "Alger", "disabled": true },
                { "key": "fuel_type", "value": "DIESEL", "disabled": true },
                { "key": "transmission", "value": "MANUAL", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Car Detail (public)",
          "request": {
            "method": "GET",
            "url": "{{API_URL}}/api/cars/1/"
          }
        },
        {
          "name": "Create Car (agency)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{API_URL}}/api/cars/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Dacia\",\n  \"model\": \"Logan\",\n  \"year\": 2022,\n  \"price_per_day\": 3500,\n  \"seats\": 5,\n  \"transmission\": \"MANUAL\",\n  \"fuel_type\": \"DIESEL\",\n  \"wilaya\": \"Alger\",\n  \"description\": \"Voiture économique en excellent état.\"\n}"
            }
          }
        },
        {
          "name": "My Cars (agency)",
          "request": {
            "method": "GET",
            "url": "{{API_URL}}/api/cars/mine/"
          }
        },
        {
          "name": "Update Car (agency)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{API_URL}}/api/cars/1/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price_per_day\": 4000,\n  \"available\": true\n}"
            }
          }
        },
        {
          "name": "Delete Car (agency)",
          "request": {
            "method": "DELETE",
            "url": "{{API_URL}}/api/cars/1/"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking (client)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{API_URL}}/api/bookings/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"car\": 1,\n  \"start_date\": \"2025-06-01\",\n  \"end_date\": \"2025-06-05\",\n  \"message\": \"Je voudrais louer cette voiture pour un voyage.\"\n}"
            }
          }
        },
        {
          "name": "My Bookings (client)",
          "request": {
            "method": "GET",
            "url": "{{API_URL}}/api/bookings/mes-reservations/"
          }
        },
        {
          "name": "Agency Bookings (agency)",
          "request": {
            "method": "GET",
            "url": "{{API_URL}}/api/bookings/agence/"
          }
        },
        {
          "name": "Confirm Booking (agency) → RabbitMQ",
          "request": {
            "method": "POST",
            "url": "{{API_URL}}/api/bookings/1/confirmer/"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "POST",
            "url": "{{API_URL}}/api/bookings/1/annuler/"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get Car Reviews (public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{API_URL}}/api/reviews/?car=1",
              "query": [{ "key": "car", "value": "1" }]
            }
          }
        },
        {
          "name": "Create Review (client, after completed booking)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{API_URL}}/api/reviews/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking\": 1,\n  \"rating\": 5,\n  \"comment\": \"Excellente voiture, je recommande !\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Stats (admin)",
          "request": {
            "method": "GET",
            "url": "{{API_URL}}/api/admin/stats/"
          }
        },
        {
          "name": "All Bookings (admin)",
          "request": {
            "method": "GET",
            "url": "{{API_URL}}/api/admin/bookings/"
          }
        }
      ]
    }
  ]
}
