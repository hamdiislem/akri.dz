# ─── Server IPs (replace with your real VM addresses) ───────
SERVER1_IP=192.168.1.10   # Infra: Traefik, Consul, RabbitMQ, PostgreSQL, Redis
SERVER2_IP=192.168.1.11   # auth-service
SERVER3_IP=192.168.1.12   # api-service
SERVER4_IP=192.168.1.13   # frontend-service
SERVER5_IP=192.168.1.14   # notification-worker

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ─── Admin account (created at auth-service startup) ────────
ADMIN_EMAIL=admin@akri.dz
ADMIN_PASSWORD=Admin123456

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ─── Per-server: set MY_IP to this server's own IP ──────────
MY_IP=192.168.1.11
